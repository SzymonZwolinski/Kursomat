@page "/register"
@using ArchitectureTester.Models
@inject ApiService ApiService

<PageTitle>Register</PageTitle>

<h1>Register</h1>

<div class="row">
    <div class="col-md-6">
        <div class="form-group mb-2">
            <label>Login</label>
            <input @bind="registerData.Login" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Email</label>
            <input @bind="registerData.Email" class="form-control" type="email" />
        </div>
        <div class="form-group mb-2">
            <label>Password</label>
            <input @bind="registerData.Password" class="form-control" type="password" />
        </div>
        <div class="form-group mb-2">
            <label>Full Name</label>
            <input @bind="registerData.FullName" class="form-control" />
        </div>
        <button class="btn btn-primary" @onclick="RegisterUser">Register</button>

        @if (registerResult != null)
        {
            <div class="alert @(registerResult.IsSuccess ? "alert-success" : "alert-danger") mt-3">
                <p>Status: @(registerResult.IsSuccess ? "Success" : "Failed")</p>
                <p>Time: @registerResult.ElapsedMilliseconds ms</p>
                @if (!registerResult.IsSuccess)
                {
                    <p>Error: @registerResult.ErrorMessage</p>
                }
            </div>
        }
    </div>
</div>

@code {
    private RegisterDto registerData = new();
    private PerformanceResult? registerResult;

    private async Task RegisterUser()
    {
        var endpoint = ApiService.CurrentArchitecture == ArchitectureType.Monolith
            ? "api/account/create"
            : "api/users/register";

        registerResult = await ApiService.PostAsync(endpoint, registerData);
        if (registerResult.IsSuccess)
        {
            registerData = new RegisterDto(); // reset form
        }
    }

    public class RegisterDto
    {
        public string Login { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string FullName { get; set; } = "";
    }
}
