@page "/courses"
@inject ApiService ApiService
@inject IJSRuntime JS

<PageTitle>Courses</PageTitle>

<h1>Courses</h1>

<div class="row">
    <div class="col-md-6">
        <h3>Create Course</h3>
        <div class="form-group mb-2">
            <label>Id</label>
            <input @bind="newCourse.Id" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Title</label>
            <input @bind="newCourse.Name" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Description</label>
            <input @bind="newCourse.Description" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Price</label>
            <input @bind="newCourse.Price" type="number" step="0.01" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Video File (Optional)</label>
            <InputFile OnChange="OnNewCourseFileSelected" class="form-control" />
        </div>
        <button class="btn btn-primary" @onclick="CreateCourse">Create</button>

        @if (createResult != null)
        {
            <div class="alert @(createResult.IsSuccess ? "alert-success" : "alert-danger") mt-3">
                <p>Status: @(createResult.IsSuccess ? "Success" : "Failed")</p>
                <p>Time: @createResult.ElapsedMilliseconds ms</p>
                @if (!createResult.IsSuccess)
                {
                    <p>Error: @createResult.ErrorMessage</p>
                }
            </div>
        }
    </div>

    <div class="col-md-6">
        <h3>Get Courses</h3>
        <button class="btn btn-secondary" @onclick="GetCourses">Load Courses</button>

        @if (getResult != null)
        {
            <div class="alert @(getResult.IsSuccess ? "alert-success" : "alert-danger") mt-3">
                <p>Status: @(getResult.IsSuccess ? "Success" : "Failed")</p>
                <p>Time: @getResult.ElapsedMilliseconds ms</p>
                @if (!getResult.IsSuccess)
                {
                    <p>Error: @getResult.ErrorMessage</p>
                }
            </div>
        }

        @if (courses != null && courses.Any())
        {
            <ul class="list-group mt-3">
                @foreach (var course in courses)
                {
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@(course.Title ?? course.Name)</strong> - $@course.Price<br/>
                                <small>@course.Description (ID: @course.Id)</small>
                            </div>
                            <div>
                                @if (course.IsPurchased)
                                {
                                    <button class="btn btn-sm btn-success me-2" @onclick="() => LoadVideoStream(course.Id)">Play Video</button>
                                }
                                <label class="btn btn-sm btn-outline-secondary mb-0">
                                    Upload / Edit Video
                                    <InputFile OnChange="(e) => UploadVideoForExistingCourse(e, course.Id)" style="display:none;" />
                                </label>
                            </div>
                        </div>

                        @if (uploadResults.ContainsKey(course.Id))
                        {
                            var uRes = uploadResults[course.Id];
                            <div class="alert @(uRes.IsSuccess ? "alert-success" : "alert-danger") mt-2 p-1">
                                <small>Upload: @(uRes.IsSuccess ? "Success" : "Failed") (@uRes.ElapsedMilliseconds ms) @uRes.ErrorMessage</small>
                            </div>
                        }

                        @if (videoUrls.ContainsKey(course.Id))
                        {
                            <div class="mt-3">
                                <video controls src="@videoUrls[course.Id]" style="width: 100%; max-height: 300px;"></video>
                            </div>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    private CreateCourseDto newCourse = new() { Id = Guid.NewGuid() };
    private IBrowserFile? newCourseVideoFile;
    private PerformanceResult? createResult;
    private Dictionary<Guid, PerformanceResult> uploadResults = new();
    private Dictionary<Guid, string> videoUrls = new();
    private PerformanceResult<List<CourseDto>>? getResult;
    private List<CourseDto>? courses;

    private void OnNewCourseFileSelected(InputFileChangeEventArgs e)
    {
        newCourseVideoFile = e.File;
    }

    private async Task CreateCourse()
    {
        // Posiadamy tu Monolit i Microserwisy, w Monolicie i Modularnym model przyjmował Title jako Name, w Micro tak samo.
        // Dodałem w UI fallback na Name/Title.
        var createReq = new
        {
            Id = newCourse.Id,
            Name = newCourse.Title, // Backend często oczekuje "Name"
            Description = newCourse.Description,
            Price = newCourse.Price
        };

        // Ponieważ CreateCourseEndpoint w monolicie i reszcie może nie przyjmować "Id" (nadpisuje je na serwerze),
        // jeśli przyjmuje, to dobrze. Jeśli nie, musimy polegać na response.
        var postRes = await ApiService.PostWithResponseAsync<CourseDto, object>("api/courses", createReq);
        createResult = new PerformanceResult { ElapsedMilliseconds = postRes.ElapsedMilliseconds, IsSuccess = postRes.IsSuccess, ErrorMessage = postRes.ErrorMessage };

        if (postRes.IsSuccess && postRes.Data != null)
        {
            var createdCourseId = postRes.Data.Id;
            if (newCourseVideoFile != null)
            {
                await UploadFileAsync(createdCourseId, newCourseVideoFile);
            }

            newCourse = new CreateCourseDto { Id = Guid.NewGuid() }; // reset form
            newCourseVideoFile = null;
        }
    }

    private async Task UploadVideoForExistingCourse(InputFileChangeEventArgs e, Guid courseId)
    {
        var file = e.File;
        var res = await UploadFileAsync(courseId, file);
        uploadResults[courseId] = res;
    }

    private async Task<PerformanceResult> UploadFileAsync(Guid courseId, IBrowserFile file)
    {
        using var content = new MultipartFormDataContent();
        // Limit to 500MB
        var streamContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 500));
        streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
        content.Add(streamContent, "file", file.Name);

        var res = await ApiService.PostFileAsync($"api/courses/{courseId}/video", content);
        return res;
    }

    private Task LoadVideoStream(Guid courseId)
    {
        var url = ApiService.BuildUrl($"api/courses/{courseId}/video");
        if (!string.IsNullOrEmpty(ApiService.Token))
        {
            url += $"?access_token={ApiService.Token}";
        }
        videoUrls[courseId] = url;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task GetCourses()
    {
        getResult = await ApiService.GetAsync<List<CourseDto>>("api/courses");
        if (getResult.IsSuccess)
        {
            courses = getResult.Data;
        }
    }

    public class CreateCourseDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
    }

    public class CourseDto
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = "";
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public bool IsPurchased { get; set; }
    }
}
