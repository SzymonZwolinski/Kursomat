@page "/orders"
@inject ApiService ApiService

<PageTitle>Orders</PageTitle>

<h1>Orders</h1>

<div class="row">
    <div class="col-md-6">
        <h3>Create Order</h3>
        <div class="form-group mb-2">
            <label>Order ID</label>
            <input @bind="newOrder.OrderId" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Customer ID</label>
            <input @bind="newOrder.CustomerId" class="form-control" />
        </div>
        <div class="form-group mb-2">
            <label>Total Amount</label>
            <input @bind="newOrder.TotalAmount" type="number" step="0.01" class="form-control" />
        </div>

        <h4>Items</h4>
        <div class="form-group mb-2 border p-2">
            <label>Course ID</label>
            <input @bind="newItem.CourseId" class="form-control mb-1" />
            <label>Price</label>
            <input @bind="newItem.Price" type="number" step="0.01" class="form-control mb-1" />
            <button class="btn btn-sm btn-secondary mt-1" @onclick="AddItemToOrder">Add Item to Order List</button>
        </div>

        @if (newOrder.Items.Any())
        {
            <ul>
                @foreach (var item in newOrder.Items)
                {
                    <li>@item.CourseId - $@item.Price</li>
                }
            </ul>
        }

        <button class="btn btn-primary" @onclick="CreateOrder">Submit Order</button>

        @if (createResult != null)
        {
            <div class="alert @(createResult.IsSuccess ? "alert-success" : "alert-danger") mt-3">
                <p>Status: @(createResult.IsSuccess ? "Success" : "Failed")</p>
                <p>Time: @createResult.ElapsedMilliseconds ms</p>
                @if (!createResult.IsSuccess)
                {
                    <p>Error: @createResult.ErrorMessage</p>
                }
            </div>
        }
    </div>

    <div class="col-md-6">
        <h3>Get Order</h3>
        <div class="form-group mb-2">
            <label>Order ID to load</label>
            <input @bind="loadOrderId" class="form-control" />
        </div>
        <button class="btn btn-secondary" @onclick="GetOrder">Load Order</button>

        @if (getResult != null)
        {
            <div class="alert @(getResult.IsSuccess ? "alert-success" : "alert-danger") mt-3">
                <p>Status: @(getResult.IsSuccess ? "Success" : "Failed")</p>
                <p>Time: @getResult.ElapsedMilliseconds ms</p>
                @if (!getResult.IsSuccess)
                {
                    <p>Error: @getResult.ErrorMessage</p>
                }
            </div>
        }

        @if (order != null)
        {
            <div class="mt-3 card p-3">
                <h4>Order Details</h4>
                <p><strong>Order ID:</strong> @order.Id</p>
                <p><strong>Customer ID:</strong> @order.CustomerId</p>
                <p><strong>Total Amount:</strong> $@order.TotalAmount</p>
                <h5>Items</h5>
                <ul>
                    @foreach(var i in order.Items)
                    {
                        <li>Course ID: @i.CourseId - $@i.Price</li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@code {
    private CreateOrderDto newOrder = new() { OrderId = Guid.NewGuid(), CustomerId = Guid.NewGuid(), Items = new() };
    private OrderItemDto newItem = new() { CourseId = Guid.NewGuid() };
    private Guid loadOrderId;
    private PerformanceResult? createResult;
    private PerformanceResult<OrderDto>? getResult;
    private OrderDto? order;

    private void AddItemToOrder()
    {
        newOrder.Items.Add(new OrderItemDto { CourseId = newItem.CourseId, Price = newItem.Price });
        newItem = new OrderItemDto { CourseId = Guid.NewGuid() }; // reset form item
    }

    private async Task CreateOrder()
    {
        createResult = await ApiService.PostAsync("api/orders", newOrder);
        if (createResult.IsSuccess)
        {
            newOrder = new CreateOrderDto { OrderId = Guid.NewGuid(), CustomerId = Guid.NewGuid(), Items = new() };
        }
    }

    private async Task GetOrder()
    {
        getResult = await ApiService.GetAsync<OrderDto>($"api/orders/{loadOrderId}");
        if (getResult.IsSuccess)
        {
            order = getResult.Data;
        }
        else
        {
            order = null;
        }
    }

    public class CreateOrderDto
    {
        public Guid OrderId { get; set; }
        public Guid CustomerId { get; set; }
        public decimal TotalAmount { get; set; }
        public List<OrderItemDto> Items { get; set; } = new();
    }

    public class OrderItemDto
    {
        public Guid CourseId { get; set; }
        public decimal Price { get; set; }
    }

    public class OrderDto
    {
        public Guid Id { get; set; }
        public Guid CustomerId { get; set; }
        public decimal TotalAmount { get; set; }
        public List<OrderItemDto> Items { get; set; } = new();
    }
}
