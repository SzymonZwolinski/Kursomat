{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "courses-route": {
        "ClusterId": "courses-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "carts-route": {
        "ClusterId": "carts-cluster",
        "Match": {
          "Path": "/api/carts/{**catch-all}"
        }
      },
      "sales-route": {
        "ClusterId": "sales-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "courses-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://courses-api-micro:8080"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://users-api-micro:8080"
          }
        }
      },
      "carts-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://carts-api-micro:8080"
          }
        }
      },
      "sales-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://sales-api-micro:8080"
          }
        }
      }
    }
  }
}
